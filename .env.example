# Copy this file to .env and adjust values if needed:
#   cp .env.example .env
#
# IMPORTANT: docker-compose.yml does NOT read this file - the "app"
# service's connection strings are hardcoded in its `environment:`
# block (using the Docker-internal hostnames "redis"/"memcached"/"db"),
# and .env is excluded from the image via .dockerignore. So this file
# only matters when you run something directly on your HOST machine
# with plain `node` (e.g. scripts/consistencyTest.js, or `npm start`
# without Docker) - that's why the defaults below point at "localhost"
# and the ports docker-compose publishes there.

REDIS_URL=redis://localhost:6379
MEMCACHED_URL=localhost:11211
DATABASE_URL=postgres://postgres:postgres@localhost:5432/products_db
API_PORT=3000
